# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# Server Configuration
PORT=3000
NODE_ENV="development"

# CORS Configuration
ALLOWED_ORIGINS="http://localhost:5173,https://*.onrender.com"

# Cookie Configuration
COOKIE_SAME_SITE="none"
COOKIE_SECURE="true"

# Database Configuration
DATABASE_URL="postgresql://neondb_owner:xxxx.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT Secrets (User Authentication)
JWT_SECRET="your_jwt_secret_key_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_key_here"

# Admin JWT Secrets (Admin Authentication)
ADMIN_JWT_SECRET="YourSuperSecretAdminJwtKeyHere"

# Admin Access Password
ADMIN_PASSWORD="admin123"

# Redis Configuration
REDIS_URL="redis://default:xxxx.ec2.redns.redis-cloud.com:13556"

# Brevo Configuration for Sending Email
BREVO_API_KEY="your_brevo_api_key_here"
BREVO_SENDER_NAME="Ticket Dashboard"
BREVO_API_URL="https://api.brevo.com/v3/smtp/email"
FROM_EMAIL="noreply@ticketdashboard.com"

# Email Configuration
SEND_OUT_MAILS="false"

# Seed Data Configuration
SEED_ON_START="true"

# Note: OTP and Auth configuration is now handled by shared constants in @repo/shared
# No need to define these values here as they are imported from the shared package